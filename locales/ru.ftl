    🧹 Дубликатов удалено перед экспортом: { $deleted_duplicates }

export_channels_caption =
    📦 База данных Telegram-каналов.

    📊 Всего записей: { $total_records }

export_groups_caption =
    📦 База данных Telegram-групп.

    📊 Всего записей: { $total_records }

export_error_generic =
